<%- include('partials/header') %>

<div class="header">
    <div>
        <h1>🏠 Dashboard</h1>
        <p class="header-subtitle">Monitoring & kontrol Spark-Core Bot</p>
    </div>
    <span class="badge badge-success">● Bot Status: <%= status %></span>
</div>

<div class="dashboard-grid">
    <div class="card stat-card">
        <div class="stat-icon stat-icon-red">⏱️</div>
        <h3>Uptime Bot</h3>
        <div class="value" id="uptime-display"><%= uptime %>s</div>
    </div>
    <div class="card stat-card">
        <div class="stat-icon stat-icon-blue">⚙️</div>
        <h3>Total Commands</h3>
        <div class="value"><%= commands.length %></div>
    </div>
    <div class="card stat-card">
        <div class="stat-icon stat-icon-orange">🤖</div>
        <h3>Bot Identity</h3>
        <div class="value" style="font-size: 1.3rem;"><%= botName %></div>
    </div>
    <div class="card stat-card">
        <div class="stat-icon stat-icon-green">💰</div>
        <h3>Total Saldo Kas</h3>
        <div class="value text-green">Rp <%= totalKas.toLocaleString('id-ID') %></div>
    </div>
</div>

<!-- Quick Actions & Sync -->
<div class="dashboard-grid">
    <div class="card">
        <div class="section-title">
            <h2>⚡ Quick Actions</h2>
        </div>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
            <a href="/kas" class="btn btn-primary btn-block">💰 Manajemen Kas</a>
            <a href="/reaction-roles" class="btn btn-secondary btn-block">🎭 Reaction Roles</a>
            <a href="/member-roles" class="btn btn-secondary btn-block">👤 Member Roles</a>
        </div>
    </div>

    <div class="card">
        <div class="section-title">
            <h2>🔄 Quick Sync Reaction Roles</h2>
        </div>
        <p style="color: var(--text-secondary); font-size: 0.85rem; margin-bottom: 1rem;">
            Klik Sync setelah redeploy untuk mengaktifkan kembali bot pada pesan lama.
        </p>
        <div class="form-group">
            <select id="syncChannelId" class="form-control" style="margin-bottom: 0.75rem;">
                <option value="">-- Pilih Channel --</option>
                <% channels.forEach(channel => { %>
                    <option value="<%= channel.id %>">#<%= channel.name %> (<%= channel.id %>)</option>
                <% }) %>
            </select>
            <button onclick="syncChannel()" class="btn btn-primary btn-block">🔄 Jalankan Sync</button>
        </div>
    </div>
</div>

<!-- Loaded Commands -->
<div class="card" style="margin-top: 1.5rem;">
    <div class="section-title">
        <h2>📦 Loaded Command Modules</h2>
        <span class="badge badge-primary"><%= commands.length %> modules</span>
    </div>
    <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
        <% commands.forEach(cmd => { %>
            <span class="badge badge-primary" style="font-size: 0.82rem;">/<%= cmd %></span>
        <% }) %>
    </div>
</div>

<script>
    let uptime = <%= uptime %>;
    const uptimeEl = document.getElementById('uptime-display');
    setInterval(() => {
        uptime++;
        const hours = Math.floor(uptime / 3600);
        const minutes = Math.floor((uptime % 3600) / 60);
        const seconds = uptime % 60;
        uptimeEl.textContent = `${hours}h ${minutes}m ${seconds}s`;
    }, 1000);
    
    async function syncChannel() {
        const channelId = document.getElementById('syncChannelId').value;
        if (!channelId) return alert('Pilih channel terlebih dahulu!');

        const btn = document.querySelector('button[onclick="syncChannel()"]');
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Syncing...';

        try {
            const res = await fetch('/api/reaction-roles/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId })
            });

            const result = await res.json();
            if (result.success) {
                alert(`Berhasil sinkronisasi ${result.syncedCount} reaction role di channel tersebut!`);
            } else {
                alert('Gagal: ' + result.error);
            }
        } catch (err) {
            alert('Kesalahan jaringan.');
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    }
</script>

<%- include('partials/footer') %>
