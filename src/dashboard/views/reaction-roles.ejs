<%- include('partials/header') %>

<div class="page-header">
    <div class="header-info">
        <h1>Reaction Roles</h1>
        <p>Kelola pesan yang memberikan role otomatis saat bereaksi.</p>
    </div>
    <div class="header-actions" style="display: flex; gap: 0.5rem; align-items: center;">
        <select id="syncChannelId" class="form-control" style="width: 200px;">
            <option value="">-- Pilih Channel --</option>
            <% channels.forEach(channel => { %>
                <option value="<%= channel.id %>">#<%= channel.name %></option>
            <% }) %>
        </select>
        <button onclick="syncChannel()" class="btn btn-secondary">🔄 Sync Channel</button>
    </div>
</div>

<div class="dashboard-grid">
    <!-- Form Tambah Reaction Role -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Buat Reaction Role Baru</h2>
        </div>
        <form id="rr-form" class="custom-form">
            <div class="form-group">
                <label for="channelId">Channel</label>
                <select id="channelId" name="channelId" required>
                    <% channels.forEach(channel => { %>
                        <option value="<%= channel.id %>">#<%= channel.name %></option>
                    <% }) %>
                </select>
            </div>

            <div class="tab-container" style="margin-bottom: 1.5rem;">
                <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                    <button type="button" class="btn btn-sm btn-secondary active" id="btn-new-msg" onclick="switchRRMode('new')">Kirim Pesan Baru</button>
                    <button type="button" class="btn btn-sm btn-secondary" id="btn-exist-msg" onclick="switchRRMode('exist')">Gunakan Pesan Sdh Ada</button>
                </div>

                <div id="mode-new-msg">
                    <div class="form-group">
                        <label for="messageContent">Isi Pesan</label>
                        <textarea id="messageContent" name="messageContent" placeholder="Ketik pesan yang akan dikirim bot..." class="form-control" style="min-height: 100px;"></textarea>
                    </div>
                    <div class="form-group">
                        <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                            <input type="checkbox" name="useEmbed" value="true" checked> Gunakan Embed (Tampilan Kotak)
                        </label>
                    </div>
                </div>

                <div id="mode-exist-msg" style="display: none;">
                    <div class="form-group">
                        <label for="messageId">Message ID</label>
                        <input type="text" id="messageId" name="messageId" placeholder="Masukkan ID pesan yang sudah ada...">
                        <small style="color: var(--text-muted); display: block; margin-top: 0.3rem;">
                            * Klik kanan pesan di Discord > Copy Message ID (Butuh Developer Mode aktif)
                        </small>
                    </div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="emoji">Emoji (Unicode atau ID)</label>
                    <input type="text" id="emoji" name="emoji" placeholder="Contoh: ✅ atau 123456789" required>
                </div>
                <div class="form-group">
                    <label for="roleId">Role</label>
                    <select id="roleId" name="roleId" required>
                        <% roles.forEach(role => { %>
                            <% if(role.name !== '@everyone') { %>
                                <option value="<%= role.id %>"><%= role.name %></option>
                            <% } %>
                        <% }) %>
                    </select>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Buat Reaction Role</button>
        </form>
    </div>

    <!-- Daftar Reaction Role -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Daftar Reaction Role</h2>
        </div>
        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Channel</th>
                        <th>Msg ID</th>
                        <th>Emoji</th>
                        <th>Role</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (reactionRoles.length === 0) { %>
                        <tr>
                            <td colspan="5" style="text-align: center;">Belum ada reaction role.</td>
                        </tr>
                    <% } else { %>
                        <% reactionRoles.forEach(rr => { %>
                            <% const role = roles.find(r => r.id === rr.roleId); %>
                            <% const channel = channels.find(c => c.id === rr.channelId); %>
                            <tr>
                                <td>#<%= channel ? channel.name : 'Unknown' %></td>
                                <td><code><%= rr.messageId.substring(0, 8) %>...</code></td>
                                <td><%= rr.emoji %></td>
                                <td><%= role ? role.name : 'Unknown' %></td>
                                <td>
                                    <button class="btn btn-danger btn-sm" onclick="deleteRR('<%= rr.messageId %>', '<%= rr.emoji %>')">Hapus</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    let currentMode = 'new';

    function switchRRMode(mode) {
        currentMode = mode;
        const btnNew = document.getElementById('btn-new-msg');
        const btnExist = document.getElementById('btn-exist-msg');
        const divNew = document.getElementById('mode-new-msg');
        const divExist = document.getElementById('mode-exist-msg');
        const inputMsgId = document.getElementById('messageId');
        const inputContent = document.getElementById('messageContent');

        if (mode === 'new') {
            btnNew.classList.add('active', 'btn-primary');
            btnNew.classList.remove('btn-secondary');
            btnExist.classList.remove('active', 'btn-primary');
            btnExist.classList.add('btn-secondary');
            divNew.style.display = 'block';
            divExist.style.display = 'none';
            inputMsgId.required = false;
            inputContent.required = true;
        } else {
            btnExist.classList.add('active', 'btn-primary');
            btnExist.classList.remove('btn-secondary');
            btnNew.classList.remove('active', 'btn-primary');
            btnNew.classList.add('btn-secondary');
            divExist.style.display = 'block';
            divNew.style.display = 'none';
            inputMsgId.required = true;
            inputContent.required = false;
        }
    }

    // Initialize mode
    switchRRMode('new');

    document.getElementById('rr-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        
        // Handle checkbox manually if not checked
        if (!data.useEmbed) data.useEmbed = false;

        // Clear unused fields based on mode
        if (currentMode === 'new') {
            delete data.messageId;
        } else {
            delete data.messageContent;
            delete data.useEmbed;
        }

        const btn = e.target.querySelector('button[type="submit"]');
        btn.disabled = true;
        btn.textContent = 'Memproses...';

        try {
            const res = await fetch('/api/reaction-roles', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();
            if (result.success) {
                location.reload();
            } else {
                alert('Gagal: ' + result.error);
                btn.disabled = false;
                btn.textContent = 'Buat Reaction Role';
            }
        } catch (err) {
            alert('Terjadi kesalahan jaringan.');
            btn.disabled = false;
            btn.textContent = 'Buat Reaction Role';
        }
    });

    async function deleteRR(messageId, emoji) {
        if (!confirm('Hapus reaction role ini?')) return;

        const res = await fetch('/api/reaction-roles', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ messageId, emoji })
        });

        const result = await res.json();
        if (result.success) {
            location.reload();
        } else {
            alert('Gagal: ' + result.error);
        }
    }

    async function syncChannel() {
        const channelId = document.getElementById('syncChannelId').value;
        if (!channelId) return alert('Pilih channel terlebih dahulu!');

        const btn = document.querySelector('button[onclick="syncChannel()"]');
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = 'Syncing...';

        try {
            const res = await fetch('/api/reaction-roles/sync', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId })
            });

            const result = await res.json();
            if (result.success) {
                alert(`Berhasil sinkronisasi ${result.syncedCount} reaction role di channel tersebut!`);
            } else {
                alert('Gagal: ' + result.error);
            }
        } catch (err) {
            alert('Kesalahan jaringan.');
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    }
</script>

<%- include('partials/footer') %>
