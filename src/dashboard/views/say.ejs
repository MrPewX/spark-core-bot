<%- include('partials/header') %>

<div class="header">
    <div>
        <h1>📢 Kirim Pesan (Say)</h1>
        <p class="header-subtitle">Kirim pesan ke channel Discord melalui bot</p>
    </div>
</div>

<div class="card">
    <form id="say-form">
        <div class="form-group">
            <label for="channel">Pilih Channel Target</label>
            <select id="channel" class="form-control" required>
                <% if (channels.length > 0) { %>
                    <% channels.forEach(ch => { %>
                        <option value="<%= ch.id %>">#<%= ch.name %></option>
                    <% }) %>
                <% } else { %>
                    <option value="">Tidak ada channel tersedia</option>
                <% } %>
            </select>
        </div>

        <div class="form-group">
            <label for="useEmbed" style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                <input type="checkbox" id="useEmbed" style="width: 1.1rem; height: 1.1rem; accent-color: var(--accent);">
                <span>Kirim sebagai Embed Message</span>
            </label>
        </div>

        <div class="form-group">
            <div style="display: flex; justify-content: space-between; align-items: flex-end;">
                <label for="message">Pesan / Konten</label>
                <small style="color: var(--text-muted); font-size: 0.75rem;">Gunakan Tab / Enter untuk mengatur posisi teks</small>
            </div>
            <textarea id="message" class="form-control" required placeholder="Tuliskan pesanmu di sini..." style="font-family: monospace; white-space: pre-wrap; margin-top: 0.5rem; min-height: 160px;"></textarea>
        </div>

        <button type="submit" class="btn btn-primary btn-block">
            📨 Kirim Pesan ke Channel
        </button>
    </form>
    
    <div id="status-message" style="display: none;" class="status-message"></div>
</div>

<script>
    // Handle tab key
    document.getElementById('message').addEventListener('keydown', function(e) {
        if (e.key === 'Tab') {
            e.preventDefault();
            const start = this.selectionStart;
            const end = this.selectionEnd;
            this.value = this.value.substring(0, start) + "\t" + this.value.substring(end);
            this.selectionStart = this.selectionEnd = start + 1;
        }
    });

    document.getElementById('say-form').addEventListener('submit', async function(e) {
        e.preventDefault();
        
        const channelId = document.getElementById('channel').value;
        const message = document.getElementById('message').value;
        const useEmbed = document.getElementById('useEmbed').checked;
        const statusEl = document.getElementById('status-message');

        if (!channelId) {
            statusEl.className = 'status-message status-error';
            statusEl.textContent = '❌ Pilih channel terlebih dahulu.';
            statusEl.style.display = 'block';
            return;
        }

        const btn = this.querySelector('button');
        btn.disabled = true;
        btn.textContent = '⏳ Mengirim...';

        try {
            const res = await fetch('/api/say', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ channelId, message, useEmbed })
            });

            const data = await res.json();

            if (data.success) {
                statusEl.className = 'status-message status-success';
                statusEl.textContent = '✅ Pesan berhasil dikirim!';
                document.getElementById('message').value = '';
            } else {
                throw new Error(data.error);
            }
        } catch (err) {
            statusEl.className = 'status-message status-error';
            statusEl.textContent = '❌ Gagal mengirim pesan: ' + err.message;
        } finally {
            statusEl.style.display = 'block';
            btn.disabled = false;
            btn.textContent = '📨 Kirim Pesan ke Channel';
            
            setTimeout(() => {
                statusEl.style.display = 'none';
            }, 3000);
        }
    });
</script>

<%- include('partials/footer') %>
