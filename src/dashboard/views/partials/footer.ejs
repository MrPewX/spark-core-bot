    </main>
    <script>
        // Set active navigation link
        const path = window.location.pathname;
        const navIdMap = {
            '/': 'nav-home',
            '/kas': 'nav-kas',
            '/say': 'nav-say',
            '/moderation': 'nav-mod',
            '/iot': 'nav-iot',
            '/ml': 'nav-ml',
            '/commands': 'nav-commands',
            '/server-manager': 'nav-server'
        };
        const id = navIdMap[path];
        if (id) {
            document.getElementById(id).classList.add('active');
        }
    </script>
